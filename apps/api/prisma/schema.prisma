// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- CORE MODELS ---

model Company {
  id                String   @id @default(uuid())
  name              String
  legalName         String?
  tin               String?  @unique
  storefrontUrl     String?
  storefrontToken   String?  @unique
  telegramChatId   String?
  telegramEnabled  Boolean  @default(false)
  telegramLinkedAt DateTime?
  telegramLinkCode String?  @unique
  telegramLinkCodeExpiresAt DateTime?
  phone             String?
  address           String?
  businessType      String?
  status            String   @default("active")
  trialStartedAt    DateTime @default(now())
  trialEndsAt       DateTime
  // TRIAL | ACTIVE | EXPIRED — platforma obunasi
  subscriptionStatus     String   @default("TRIAL")
  subscriptionNote       String?
  subscriptionActivatedAt DateTime?

  users             CompanyUser[]
  products          Product[]
  productCategories ProductCategory[]
  warehouses        Warehouse[]
  stockBalances     StockBalance[]
  stockMovements    StockMovement[]
  productMappings   ProductMapping[]
  partnerships      Partner[] @relation("OwnCompany")
  partnerOf         Partner[] @relation("PartnerCompany")
  
  b2bOrdersSent     B2BOrder[] @relation("Buyer")
  b2bOrdersReceived B2BOrder[] @relation("Seller")
  
  dispatchesSent    Dispatch[] @relation("Sender")
  dispatchesReceived Dispatch[] @relation("Receiver")

  productVariants   ProductVariant[]
  goodsReceiptsAsBuyer  GoodsReceipt[] @relation("BuyerReceipt")
  goodsReceiptsAsSeller GoodsReceipt[] @relation("SellerReceipt")

  debtsAsDebtor     DebtEntry[] @relation("Debtor")
  debtsAsCreditor   DebtEntry[] @relation("Creditor")
  tasks             Task[]
  workflowDefinitions WorkflowDefinition[]
  telegramChatBindings TelegramChatBinding[]
  telegramActionRecords TelegramActionRecord[]
  posSales          PosSale[]
  retailCustomers   RetailCustomer[]
  retailReceivables RetailReceivable[]
  retailCustomerLedgerEntries RetailCustomerLedgerEntry[]

  posCreditEnabled       Boolean  @default(false) // nasiya (CREDIT) sotuv
  posMaxDiscountPercent  Decimal? @db.Decimal(5, 2) // kassir chegirma limiti (%), null = 15
  fieldTasks        FieldTask[]
  userStocks        UserStock[]
  pickTasks         PickTask[]
  inventoryCounts   InventoryCount[]
  stockBlocks       StockBlock[]
  inventoryVarianceTolerancePct Decimal @default(1) @db.Decimal(5, 2)
  expenseCategories ExpenseCategory[]
  expenses          Expense[]
  partnerLedgerContacts PartnerLedgerContact[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TelegramChatBinding {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  role        String
  moduleKey   String
  chatId      String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, moduleKey])
  @@unique([companyId, role, moduleKey])
}

model TelegramActionRecord {
  id              String    @id @default(uuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id])
  chatId          String
  moduleKey       String
  actionKey       String
  targetType      String
  targetId        String
  payload         Json?
  status          String    @default("PENDING") // PENDING, DONE, FAILED
  callbackQueryId String?   @unique
  errorMessage    String?
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId, status])
  @@index([chatId])
}

// Veb "Parolni unutdingizmi" -> Telegram /start=rp_<code>
model TelegramBotIntent {
  id        String    @id @default(uuid())
  code      String    @unique
  intent    String    // PASSWORD_RESET
  login     String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([intent, expiresAt])
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  phone        String?  @unique
  email        String?  @unique
  login        String   @unique
  passwordHash String
  status       String   @default("active")
  telegramChatId   String?  @unique
  telegramLinkedAt DateTime?
  
  companies    CompanyUser[]
  assignedTasks Task[] @relation("Assignee")
  createdTasks  Task[] @relation("Creator")
  
  notifications Notification[]
  posSalesAsCashier PosSale[] @relation("PosCashier")
  posSalesVoided    PosSale[] @relation("PosVoider")
  retailReceivablePayments RetailReceivablePayment[]
  retailCustomerLedgerEntries RetailCustomerLedgerEntry[]
  fieldTasksAssigned FieldTask[] @relation("FieldTaskAssignee")
  fieldTasksCreated  FieldTask[] @relation("FieldTaskCreator")
  fieldTasksApproved FieldTask[] @relation("FieldTaskApprover")
  userStocks         UserStock[]
  expensesCreated    Expense[] @relation("ExpenseCreator")
  expensesApproved   Expense[] @relation("ExpenseApprover")
  partnerLedgerOperations PartnerLedgerOperation[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CompanyUser {
  id         String   @id @default(uuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  role       String   @default("OWNER") // OWNER, MANAGER, ACCOUNTANT, WAREHOUSE, SALES, FIELD_WORKER
  // SALES va WAREHOUSE rollar uchun majburiy biriktiriladi (kassir/omborchi qaysi
  // ombor/do'konda ishlaydi). OWNER/MANAGER/ACCOUNTANT uchun null bo'ladi.
  // Bir necha ombor kerak bo'lsa keyinroq alohida M2M jadval qo'shiladi.
  warehouseId String?
  warehouse   Warehouse? @relation("CompanyUserWarehouse", fields: [warehouseId], references: [id])
  assignedPickTasks PickTask[]
  /// Rol defaultidan qo‘shimcha ruxsatlar (masalan pos.credit)
  grantPermissions String[] @default([])
  /// Rol defaultidan olib tashlangan ruxsatlar
  denyPermissions  String[] @default([])

  createdAt  DateTime @default(now())

  @@index([companyId, userId])
  @@index([warehouseId])
}

// --- PRODUCT & INVENTORY ---

model ProductCategory {
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  warehouseId String?
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  name      String
  parentId  String?
  parent    ProductCategory? @relation("CategoryToCategory", fields: [parentId], references: [id])
  children  ProductCategory[] @relation("CategoryToCategory")
  status    String    @default("ACTIVE") // ACTIVE, INACTIVE, ARCHIVED
  
  products  Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([companyId])
  @@index([warehouseId])
}

model Product {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  categoryId  String?
  category    ProductCategory? @relation(fields: [categoryId], references: [id])
  description String?
  imageUrl    String?
  unit        String   @default("dona")
  type        String   @default("GOODS") // GOODS, SERVICE, RAW_MATERIAL, FINISHED_GOOD
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE, ARCHIVED
  
  variants    ProductVariant[]
  
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, status, createdAt])
  @@index([companyId, categoryId])
}

model ProductVariant {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  name          String
  sku           String?
  barcode       String?
  attributesJson Json?
  salePrice     Decimal  @db.Decimal(15, 2)
  purchasePrice Decimal? @db.Decimal(15, 2)
  currency      String   @default("UZS")
  status        String   @default("ACTIVE") // ACTIVE, INACTIVE, ARCHIVED
  isPublishedToWebsite Boolean @default(false)
  publishedAt   DateTime?
  
  stockBalances StockBalance[]
  movements     StockMovement[]
  mappings      ProductMapping[]
  orderItems    B2BOrderItem[]
  dispatchItems DispatchItem[]
  goodsReceiptItems GoodsReceiptItem[]
  posSaleItems  PosSaleItem[]
  userStocks    UserStock[]
  pickTasks      PickTask[]
  inventoryCountItems InventoryCountItem[]
  stockBlocks    StockBlock[]

  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([isPublishedToWebsite])
  @@index([sku])
  @@index([barcode])
  @@unique([companyId, sku])
  @@unique([companyId, barcode])
}

model Warehouse {
  id         String   @id @default(uuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  name       String
  address    String?
  fieldConfig Json?
  status     String   @default("ACTIVE") // ACTIVE, INACTIVE, ARCHIVED
  
  stockBalances StockBalance[]
  movements     StockMovement[]
  dispatches    Dispatch[]
  categories    ProductCategory[]
  posSales      PosSale[]
  companyUsers  CompanyUser[] @relation("CompanyUserWarehouse")
  fieldTasks    FieldTask[]
  userStocks    UserStock[]
  pickTasks      PickTask[]
  inventoryCounts InventoryCount[]
  stockBlocks    StockBlock[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
}

model StockBalance {
  id               String         @id @default(uuid())
  companyId        String
  company          Company        @relation(fields: [companyId], references: [id])
  warehouseId      String
  warehouse        Warehouse      @relation(fields: [warehouseId], references: [id])
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  quantity         Decimal        @default(0) @db.Decimal(15, 4)
  reservedQuantity Decimal        @default(0) @db.Decimal(15, 4)
  blockedQuantity  Decimal        @default(0) @db.Decimal(15, 4) // Inventarizatsiya bloki

  reservations     StockReservation[]

  updatedAt        DateTime       @updatedAt

  @@unique([warehouseId, productVariantId])
  @@index([companyId])
  @@index([warehouseId])
  @@index([productVariantId])
  @@index([companyId, productVariantId])
  @@index([companyId, warehouseId])
}

// ATP — Available-to-Promise: har tasdiqlangan buyurtma uchun rezerv
model StockReservation {
  id               String            @id @default(uuid())
  companyId        String
  warehouseId      String
  productVariantId String
  orderId          String
  quantity         Decimal           @db.Decimal(15, 4)
  status           ReservationStatus @default(ACTIVE)
  expiresAt        DateTime?

  stockBalance     StockBalance      @relation(fields: [warehouseId, productVariantId], references: [warehouseId, productVariantId])
  order            B2BOrder          @relation(fields: [orderId], references: [id])

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([companyId])
  @@index([orderId])
  @@index([warehouseId, productVariantId])
  @@index([status])
}

enum ReservationStatus {
  ACTIVE    // Buyurtma tasdiqlangan, tovar hali jo'natilmagan
  RELEASED  // Buyurtma bekor qilindi — rezerv bo'shatildi
  CONSUMED  // PGI bajarildi — haqiqiy chiqim bo'ldi
}

model StockMovement {
  id               String         @id @default(uuid())
  companyId        String
  company          Company        @relation(fields: [companyId], references: [id])
  warehouseId      String
  warehouse        Warehouse      @relation(fields: [warehouseId], references: [id])
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  type             String         // IN, OUT, ADJUSTMENT, RESERVE, UNRESERVE, TRANSFER
  quantity         Decimal        @db.Decimal(15, 4)
  sourceType       String?        // MANUAL, PRODUCT_INITIAL, DISPATCH, GOODS_RECEIPT, ADJUSTMENT, TRANSFER
  sourceId         String?        // reference to entity id
  createdBy        String?
  note             String?
  
  createdAt        DateTime       @default(now())

  @@index([companyId])
  @@index([warehouseId])
  @@index([productVariantId])
}

// --- B2B & PARTNERS ---

model Partner {
  id               String   @id @default(uuid())
  ownerCompanyId   String
  ownerCompany     Company  @relation("OwnCompany", fields: [ownerCompanyId], references: [id])
  partnerCompanyId String
  partnerCompany   Company  @relation("PartnerCompany", fields: [partnerCompanyId], references: [id])
  status           String   @default("PENDING") // PENDING, ACTIVE, REJECTED, BLOCKED
  warehouseVisibilityConfig Json?
  
  createdBy        String?
  acceptedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([ownerCompanyId, partnerCompanyId])
  @@index([ownerCompanyId])
  @@index([partnerCompanyId])
}

model ProductMapping {
  id                  String         @id @default(uuid())

  companyId           String
  company             Company        @relation(fields: [companyId], references: [id])
  
  partnerCompanyId    String
  
  partnerProductName  String
  partnerSku          String?
  partnerBarcode      String?

  ownProductVariantId String
  ownProductVariant   ProductVariant @relation(fields: [ownProductVariantId], references: [id])

  conversionRatio     Decimal        @default(1) @db.Decimal(15, 4)
  unitMapping         String?
  status              String         @default("ACTIVE") // ACTIVE, INACTIVE

  createdBy           String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([companyId])
  @@index([partnerCompanyId])
  @@index([ownProductVariantId])
  @@unique([companyId, partnerCompanyId, partnerProductName, partnerSku])
}

model B2BOrder {
  id                   String   @id @default(uuid())
  buyerCompanyId       String
  buyer                Company  @relation("Buyer", fields: [buyerCompanyId], references: [id])
  sellerCompanyId      String
  seller               Company  @relation("Seller", fields: [sellerCompanyId], references: [id])
  status               String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, IN_PROGRESS, DISPATCHED, RECEIVED, COMPLETED, CANCELLED
  expectedDeliveryDate DateTime?
  note                 String?
  
  items                B2BOrderItem[]
  dispatches           Dispatch[]
  goodsReceipts        GoodsReceipt[]
  invoices             Invoice[]
  reservations         StockReservation[]

  createdBy            String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([buyerCompanyId])
  @@index([sellerCompanyId])
  @@index([buyerCompanyId, status, createdAt])
  @@index([sellerCompanyId, status, createdAt])
}

model B2BOrderItem {
  id                  String   @id @default(uuid())
  orderId             String
  order               B2BOrder @relation(fields: [orderId], references: [id])
  productVariantId    String?
  productVariant      ProductVariant? @relation(fields: [productVariantId], references: [id])
  productNameSnapshot String
  quantity            Decimal  @db.Decimal(15, 4)
  expectedPrice       Decimal? @db.Decimal(15, 2)
  expectedCurrency    String   @default("UZS")
  mappingStatus       String   @default("PENDING") // PENDING, MAPPED, REQUIRED
  
  createdAt           DateTime @default(now())

  @@index([orderId])
}

// --- FLOW: DISPATCH -> RECEIPT -> DEBT ---

model Dispatch {
  id               String   @id @default(uuid())
  dispatchNumber   String
  orderId          String
  order            B2BOrder @relation(fields: [orderId], references: [id])
  sellerCompanyId  String
  seller           Company  @relation("Sender", fields: [sellerCompanyId], references: [id])
  buyerCompanyId   String
  buyer            Company  @relation("Receiver", fields: [buyerCompanyId], references: [id])
  warehouseId      String
  warehouse        Warehouse @relation(fields: [warehouseId], references: [id])
  
  status           String   @default("DRAFT") // DRAFT, SENT, CANCELLED
  
  items            DispatchItem[]
  pickTasks        PickTask[]
  goodsReceipts    GoodsReceipt[]

  createdBy        String
  sentAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([orderId])
  @@index([sellerCompanyId])
  @@index([buyerCompanyId])
  @@index([warehouseId])
}

model DispatchItem {
  id                  String   @id @default(uuid())
  dispatchId          String
  dispatch            Dispatch @relation(fields: [dispatchId], references: [id])
  productVariantId    String
  productVariant      ProductVariant @relation(fields: [productVariantId], references: [id])
  productNameSnapshot String
  quantity            Decimal  @db.Decimal(15, 4)
  
  createdAt           DateTime @default(now())

  @@index([dispatchId])
  @@index([productVariantId])
}

model PickTask {
  id               String      @id @default(uuid())
  dispatchId       String
  dispatch         Dispatch    @relation(fields: [dispatchId], references: [id])
  companyId        String
  company          Company     @relation(fields: [companyId], references: [id])
  warehouseId      String
  warehouse        Warehouse   @relation(fields: [warehouseId], references: [id])
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  productNameSnapshot String
  binLocation         String?
  quantityRequired    Decimal     @db.Decimal(15, 4)
  quantityPicked      Decimal     @default(0) @db.Decimal(15, 4)
  scannedBarcodes     String[]    @default([])

  assignedTo          String?
  assignee            CompanyUser? @relation(fields: [assignedTo], references: [id])
  status              PickStatus   @default(PENDING)
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([dispatchId])
  @@index([companyId, status])
  @@index([warehouseId, status])
  @@index([assignedTo, status])
  @@index([productVariantId])
}

enum PickStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model InventoryCount {
  id          String               @id @default(uuid())
  companyId   String
  company     Company              @relation(fields: [companyId], references: [id])
  warehouseId String
  warehouse   Warehouse            @relation(fields: [warehouseId], references: [id])
  reference   String
  status      InventoryCountStatus @default(IN_PROGRESS)
  startedAt   DateTime             @default(now())
  completedAt DateTime?
  initiatedBy String
  approvedBy  String?

  items       InventoryCountItem[]

  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([companyId])
  @@index([warehouseId, status])
  @@unique([companyId, reference])
}

model InventoryCountItem {
  id               String          @id @default(uuid())
  inventoryCountId String
  inventoryCount   InventoryCount  @relation(fields: [inventoryCountId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant  @relation(fields: [productVariantId], references: [id])
  binLocation      String?

  systemQuantity   Decimal         @db.Decimal(15, 4)
  countedQuantity  Decimal?        @db.Decimal(15, 4)
  variance         Decimal?        @db.Decimal(15, 4)
  variancePct      Decimal?        @db.Decimal(5, 2)
  status           CountItemStatus @default(PENDING)
  scannedAt        DateTime?
  scannedBy        String?
  note             String?

  @@index([inventoryCountId])
  @@index([productVariantId])
}

model StockBlock {
  id               String      @id @default(uuid())
  companyId        String
  company          Company     @relation(fields: [companyId], references: [id])
  warehouseId      String
  warehouse        Warehouse   @relation(fields: [warehouseId], references: [id])
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  reason           BlockReason
  sourceId         String
  blockedQty       Decimal     @db.Decimal(15, 4)
  createdAt        DateTime    @default(now())
  removedAt        DateTime?
  createdBy        String

  @@index([companyId])
  @@index([warehouseId, productVariantId])
  @@unique([warehouseId, productVariantId, reason, sourceId])
}

enum InventoryCountStatus {
  DRAFT
  IN_PROGRESS
  PENDING_APPROVAL
  COMPLETED
  CANCELLED
}

enum CountItemStatus {
  PENDING
  COUNTED
  APPROVED
  REJECTED
  RECOUNTING
}

enum BlockReason {
  INVENTORY_COUNT
  QUALITY_CHECK
  MANUAL
}

model GoodsReceipt {
  id               String   @id @default(uuid())
  orderId          String
  order            B2BOrder @relation(fields: [orderId], references: [id])
  dispatchId       String
  dispatch         Dispatch @relation(fields: [dispatchId], references: [id])
  buyerCompanyId   String
  buyerCompany     Company  @relation("BuyerReceipt", fields: [buyerCompanyId], references: [id])
  sellerCompanyId  String
  sellerCompany    Company  @relation("SellerReceipt", fields: [sellerCompanyId], references: [id])
  
  status           String   @default("PENDING") // PENDING, ACCEPTED, PARTIALLY_ACCEPTED, REJECTED, DISPUTED
  
  items            GoodsReceiptItem[]
  debtEntries      DebtEntry[]

  note             String?
  receivedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([orderId])
  @@index([dispatchId])
  @@index([buyerCompanyId])
}

model GoodsReceiptItem {
  id                  String       @id @default(uuid())
  receiptId           String
  receipt             GoodsReceipt @relation(fields: [receiptId], references: [id])
  productVariantId    String?      
  productVariant      ProductVariant? @relation(fields: [productVariantId], references: [id])
  productNameSnapshot String
  quantity            Decimal      @db.Decimal(15, 4) // Dispatched quantity
  receivedQuantity    Decimal?     @db.Decimal(15, 4) // Actual received quantity
  
  createdAt           DateTime     @default(now())

  @@index([receiptId])
}

model Invoice {
  id               String   @id @default(uuid())
  orderId          String
  order            B2BOrder @relation(fields: [orderId], references: [id])
  invoiceNumber    String   @unique
  totalAmount      Decimal  @db.Decimal(15, 2)
  status           String   @default("SENT")
  
  createdAt        DateTime @default(now())
}

model DebtEntry {
  id               String   @id @default(uuid())
  debtorId         String
  debtor           Company  @relation("Debtor", fields: [debtorId], references: [id])
  creditorId       String
  creditor         Company  @relation("Creditor", fields: [creditorId], references: [id])
  amount           Decimal  @db.Decimal(15, 2)
  remainingAmount  Decimal  @db.Decimal(15, 2)
  currency         String   @default("UZS")
  status           String   @default("OPEN") // OPEN, PARTIAL, PAID
  receiptId        String?
  receipt          GoodsReceipt? @relation(fields: [receiptId], references: [id])
  
  payments         DebtPaymentRecord[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DebtPaymentRecord {
  id               String   @id @default(uuid())
  debtEntryId      String
  debtEntry        DebtEntry @relation(fields: [debtEntryId], references: [id])
  amount           Decimal  @db.Decimal(15, 2)
  status           String   @default("PENDING") // PENDING, CONFIRMED, REJECTED
  notes            String?
  
  createdBy        String
  confirmedBy      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// --- Ichki xarajatlar (EXPENSES moduli) ---

model ExpenseCategory {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  expenses  Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model Expense {
  id           String          @id @default(uuid())
  companyId    String
  company      Company         @relation(fields: [companyId], references: [id])
  categoryId   String
  category     ExpenseCategory @relation(fields: [categoryId], references: [id])
  amount       Decimal         @db.Decimal(15, 2)
  currency     String          @default("UZS")
  expenseDate  DateTime
  description  String?
  notes        String?
  status       String          @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectReason String?
  createdById  String
  createdBy    User            @relation("ExpenseCreator", fields: [createdById], references: [id])
  approvedById String?
  approvedBy   User?           @relation("ExpenseApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([companyId, expenseDate])
  @@index([categoryId])
}

// --- Hamkor daftari (tizimda bo‘lmagan hamkorlar, qo‘lda hisob) ---

model PartnerLedgerContact {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  name            String
  phone           String?
  telegramChatId  String?
  telegramLinkedAt DateTime?
  telegramLinkStatus String @default("UNLINKED") // UNLINKED, LINKED
  tag             String?
  notes           String?
  /// Kelajakda tizimdagi Partner/Company bilan bog‘lash
  linkedPartnerId String?
  isActive        Boolean  @default(true)
  operations      PartnerLedgerOperation[]
  saleOrderStatuses PartnerLedgerSaleOrderStatus[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, isActive])
  @@index([companyId, name])
  @@index([phone])
  @@index([telegramChatId])
}

model PartnerLedgerOperation {
  id            String               @id @default(uuid())
  companyId     String
  contactId     String
  contact       PartnerLedgerContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  /// MATERIAL_IN | SALE_OUT | RECEIPT_FROM_PARTNER | PAYMENT_TO_PARTNER
  type          String
  amount        Decimal              @db.Decimal(15, 2)
  currency      String               @default("UZS")
  operationDate DateTime
  notes         String?
  createdById   String
  createdBy     User                 @relation(fields: [createdById], references: [id])
  /// STOCK_IN_MANUAL | STOCK_IN_EXCEL | STOCK_OUT_MANUAL | MANUAL (default)
  sourceType    String?
  sourceId      String?
  reversedById  String?
  quantity      Decimal?             @db.Decimal(15, 4)
  productSummary String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, sourceType, sourceId, currency], map: "partner_ledger_op_stock_source")
  @@index([companyId, contactId])
  @@index([contactId, operationDate])
  @@index([companyId, operationDate])
  @@index([companyId, sourceType, sourceId])
}

model PartnerLedgerSaleOrderStatus {
  companyId   String
  contactId   String
  batchId     String
  /// SENT | ACCEPTED | PARTIAL | REJECTED
  status      String
  comment     String?
  source      String               @default("SYSTEM")
  updatedById String?
  updatedAt   DateTime             @default(now())
  createdAt   DateTime             @default(now())

  contact PartnerLedgerContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([companyId, batchId])
  @@index([companyId, contactId, updatedAt])
  @@index([status])
}

// --- UTILITY: TASKS, NOTIFS, AUDIT ---

model Task {
  id               String   @id @default(uuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])
  sourceType       String?
  sourceId         String?
  title            String
  description      String?
  assignedRole     String?
  status           String   @default("TODO") // TODO, IN_PROGRESS, DONE
  priority         String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  creatorId        String
  creator          User     @relation("Creator", fields: [creatorId], references: [id])
  assigneeId       String?
  assignee         User?    @relation("Assignee", fields: [assigneeId], references: [id])
  dueDate          DateTime?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId])
  @@index([assigneeId])
  @@index([sourceType, sourceId])
}

model Notification {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  title            String
  message          String
  type             String   // INFO, WARNING, SUCCESS, ERROR
  moduleKey        String?
  eventKey         String?
  isRead           Boolean  @default(false)
  
  createdAt        DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([userId, moduleKey, createdAt(sort: Desc)])
}

/// Bildirishnoma yetkazish holati (Telegram, keyinchalik boshqa kanallar)
model NotificationDelivery {
  id             String    @id @default(uuid())
  companyId      String
  notificationId String?
  channel        String    // TELEGRAM, IN_APP, SOCKET
  status         String    @default("PENDING") // PENDING, SENT, FAILED, RETRYING, DEAD
  attempt        Int       @default(0)
  maxAttempts    Int       @default(5)
  target         String?   // chatId yoki company broadcast marker
  moduleKey      String?
  eventKey       String?
  dedupKey       String?
  payload        Json?
  lastError      String?
  sentAt         DateTime?
  nextRetryAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([companyId, status])
  @@index([dedupKey])
  @@index([status, nextRetryAt])
}

model AuditLog {
  id               String   @id @default(uuid())
  companyId        String
  userId           String
  action           String   // e.g. "product.create"
  entityType       String   // e.g. "PRODUCT"
  entityId         String
  oldData          Json?
  newData          Json?
  
  createdAt        DateTime @default(now())
}

model ProductImportJob {
  id           String   @id @default(uuid())
  companyId    String
  userId       String
  status       String   @default("QUEUED") // QUEUED, RUNNING, COMPLETED, FAILED
  totalRows    Int      @default(0)
  processedRows Int     @default(0)
  successRows  Int      @default(0)
  failedRows   Int      @default(0)
  errorMessage String?
  /// Excel import — hamkor daftari kartochkasi (ixtiyoriy)
  partnerLedgerContactId String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stagingRows  ProductImportStagingRow[]

  @@index([companyId, status])
  @@index([createdAt])
}

model ProductImportStagingRow {
  id            String   @id @default(uuid())
  jobId         String
  job           ProductImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rowIndex      Int
  payload       Json
  status        String   @default("PENDING") // PENDING, PROCESSED, FAILED
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([jobId, status])
  @@unique([jobId, rowIndex])
}

// --- SYSTEM MODULES & FEATURES ---

model Module {
  id          String   @id @default(uuid())
  key         String   @unique // e.g. "WAREHOUSE", "B2B", "DEBT"
  name        String
  description String?
  
  features    Feature[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Feature {
  id          String   @id @default(uuid())
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id])
  key         String   @unique // e.g. "PARTIAL_RECEIPT", "STOCK_ADJUSTMENT"
  name        String
  description String?
  
  companyFeatures CompanyFeature[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CompanyFeature {
  id          String   @id @default(uuid())
  companyId   String
  featureId   String
  feature     Feature  @relation(fields: [featureId], references: [id])
  enabled     Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, featureId])
}

model WorkflowDefinition {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  eventKey    String
  name        String
  enabled     Boolean  @default(true)

  steps       WorkflowStep[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([eventKey])
}

model WorkflowStep {
  id                   String              @id @default(uuid())
  workflowDefinitionId String
  workflowDefinition   WorkflowDefinition  @relation(fields: [workflowDefinitionId], references: [id])
  stepKey              String
  role                 String
  orderIndex           Int
  required             Boolean             @default(true)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([workflowDefinitionId])
}

// --- POS (Point of Sale) ---
// Universal kassa moduli. MVP: naqd to'lov, smenasiz, anonim mijoz, umumiy summa
// chegirmasi. Chek yopilganda avto Stock OUT (sourceType: POS_SALE).
// Keyinchalik: smena (PosShift), boshqa to'lov turlari (CARD/TRANSFER/CREDIT),
// qisman qaytarish, mijoz katalogi va item-level chegirmalar qo'shilishi mumkin.

model PosSale {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])

  saleNumber      String   // har kompaniya ichida unique, masalan POS-20260512-000123

  subtotal        Decimal  @default(0) @db.Decimal(15, 2) // chegirmagacha (qatorlar yig'indisi)
  discountAmount  Decimal  @default(0) @db.Decimal(15, 2) // umumiy summa chegirmasi
  totalAmount     Decimal  @default(0) @db.Decimal(15, 2) // to'lanishi kerak: subtotal - discountAmount
  currency        String   @default("UZS")

  status          String   @default("DRAFT") // DRAFT, COMPLETED, VOIDED

  // Naqd to'lov info (MVP'da bitta CASH tranzaksiyaga to'g'ri keladi)
  cashReceived    Decimal? @db.Decimal(15, 2)
  cashChange      Decimal? @db.Decimal(15, 2)

  note            String?

  retailCustomerId       String?
  retailCustomer         RetailCustomer? @relation(fields: [retailCustomerId], references: [id])
  customerNameSnapshot   String?
  customerPhoneSnapshot  String?

  items           PosSaleItem[]
  payments        PosPayment[]
  receivable      RetailReceivable?
  ledgerEntries   RetailCustomerLedgerEntry[]

  cashierId       String
  cashier         User     @relation("PosCashier", fields: [cashierId], references: [id])

  completedAt     DateTime?
  voidedAt        DateTime?
  voidedById      String?
  voidedBy        User?    @relation("PosVoider", fields: [voidedById], references: [id])
  voidReason      String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([companyId, saleNumber])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@index([warehouseId])
  @@index([cashierId])
  @@index([retailCustomerId])
}

model PosSaleItem {
  id                  String   @id @default(uuid())
  saleId              String
  sale                PosSale  @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productVariantId    String
  productVariant      ProductVariant @relation(fields: [productVariantId], references: [id])
  productNameSnapshot String
  skuSnapshot         String?
  barcodeSnapshot     String?

  quantity            Decimal  @db.Decimal(15, 4)
  listPrice           Decimal? @db.Decimal(15, 2) // variant salePrice snapshot
  unitPrice           Decimal  @db.Decimal(15, 2)
  lineTotal           Decimal  @db.Decimal(15, 2) // quantity * unitPrice

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([saleId])
  @@index([productVariantId])
}

model PosPayment {
  id          String   @id @default(uuid())
  saleId      String
  sale        PosSale  @relation(fields: [saleId], references: [id], onDelete: Cascade)

  method      String   // CASH (MVP), keyinchalik: CARD, TRANSFER, CREDIT
  amount      Decimal  @db.Decimal(15, 2)
  reference   String?  // tashqi tranzaksiya raqami / izoh

  createdAt   DateTime @default(now())

  @@index([saleId])
}

// --- Chakana mijozlar (POS) — B2B Partner / DebtEntry dan alohida ---

model RetailCustomer {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  phone     String?
  isGuest   Boolean  @default(false)
  // true = chakana POS mijozi (POS markazi / kassa); B2B hamkor emas
  isPosRegistry Boolean @default(false)
  notes     String?
  // Oldindan to'langan avans (valyuta bo'yicha)
  prepaidBalance    Decimal @default(0) @db.Decimal(15, 2)
  prepaidBalanceUsd Decimal @default(0) @db.Decimal(15, 2)

  sales       PosSale[]
  receivables RetailReceivable[]
  ledgerEntries RetailCustomerLedgerEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, name])
}

// Mijoz hisobi — debet / kredit daftari (POS markazi)
model RetailCustomerLedgerEntry {
  id               String         @id @default(uuid())
  companyId        String
  company          Company        @relation(fields: [companyId], references: [id])
  retailCustomerId String
  retailCustomer   RetailCustomer @relation(fields: [retailCustomerId], references: [id], onDelete: Cascade)

  operation    String
  debit        Decimal  @default(0) @db.Decimal(15, 2)
  credit       Decimal  @default(0) @db.Decimal(15, 2)
  balanceAfter Decimal  @db.Decimal(15, 2)
  currency     String   @default("UZS")
  note         String?

  posSaleId      String?
  posSale        PosSale? @relation(fields: [posSaleId], references: [id])
  receivableId   String?
  paymentId      String?
  createdById      String?
  createdBy        User?   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([retailCustomerId, createdAt])
  @@index([companyId, createdAt])
}

model RetailReceivable {
  id               String         @id @default(uuid())
  companyId        String
  company          Company        @relation(fields: [companyId], references: [id])
  retailCustomerId String
  retailCustomer   RetailCustomer @relation(fields: [retailCustomerId], references: [id])
  posSaleId        String         @unique
  posSale          PosSale        @relation(fields: [posSaleId], references: [id])

  amount          Decimal  @db.Decimal(15, 2)
  remainingAmount Decimal  @db.Decimal(15, 2)
  currency        String   @default("UZS")
  status          String   @default("OPEN") // OPEN, PARTIAL, PAID

  payments RetailReceivablePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([retailCustomerId])
}

model RetailReceivablePayment {
  id           String           @id @default(uuid())
  receivableId String
  receivable   RetailReceivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)
  amount       Decimal          @db.Decimal(15, 2)
  notes        String?
  createdById  String
  createdBy    User             @relation(fields: [createdById], references: [id])
  createdAt    DateTime         @default(now())

  @@index([receivableId])
}

// --- FIELD SERVICE (dala xodimlari) ---

model UserStock {
  id                 String         @id @default(uuid())
  companyId          String
  company            Company        @relation(fields: [companyId], references: [id])
  userId             String
  user               User           @relation(fields: [userId], references: [id])
  productVariantId   String
  productVariant     ProductVariant @relation(fields: [productVariantId], references: [id])
  sourceWarehouseId  String
  sourceWarehouse    Warehouse      @relation(fields: [sourceWarehouseId], references: [id])
  quantity           Int            @default(0)
  updatedAt          DateTime       @updatedAt

  @@unique([userId, productVariantId, sourceWarehouseId])
  @@index([companyId])
  @@index([userId])
}

model FieldTask {
  id                  String   @id @default(uuid())
  companyId           String
  company             Company  @relation(fields: [companyId], references: [id])
  assigneeId          String
  assignee            User     @relation("FieldTaskAssignee", fields: [assigneeId], references: [id])
  sourceWarehouseId   String
  sourceWarehouse     Warehouse @relation(fields: [sourceWarehouseId], references: [id])
  createdById         String?
  createdBy           User?    @relation("FieldTaskCreator", fields: [createdById], references: [id])
  approvedById        String?
  approvedBy          User?    @relation("FieldTaskApprover", fields: [approvedById], references: [id])
  approvedAt          DateTime?

  title               String
  description         String?
  customerName        String?
  customerPhone       String?
  address             String?
  lat                 Float?
  lng                 Float?
  scheduledAt         DateTime?

  status              String   @default("ASSIGNED")
  // ASSIGNED | IN_PROGRESS | REPORTED | APPROVED | REJECTED | NEEDS_FIX | CANCELED
  plannedItems        Json     // [{ variantId, qty, label? }]

  report              FieldTaskReport?
  approvals           FieldTaskApproval[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([companyId, status])
  @@index([assigneeId, status])
  @@index([sourceWarehouseId])
}

model FieldTaskReport {
  id            String    @id @default(uuid())
  fieldTaskId   String    @unique
  fieldTask     FieldTask @relation(fields: [fieldTaskId], references: [id], onDelete: Cascade)
  items         Json      // [{ variantId, usedQty, returnedQty, lostQty }]
  photos        Json      @default("[]")
  gpsLat        Float?
  gpsLng        Float?
  gpsDistanceM  Float?
  comment       String?
  submittedAt   DateTime  @default(now())

  approvals     FieldTaskApproval[]
}

model FieldTaskApproval {
  id          String          @id @default(uuid())
  reportId    String
  report      FieldTaskReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  fieldTaskId String
  fieldTask   FieldTask       @relation(fields: [fieldTaskId], references: [id], onDelete: Cascade)
  approverId  String?
  decision    String          // APPROVED | REJECTED | NEEDS_FIX
  reason      String?
  channel     String          @default("WEB") // WEB | TELEGRAM
  decidedAt   DateTime        @default(now())

  @@index([fieldTaskId])
  @@index([reportId])
}
