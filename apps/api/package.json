{
  "name": "axis-erp-api",
  "version": "0.0.1",
  "description": "B2B ERP Platform API",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "postinstall": "prisma generate",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:sql-full": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script",
    "db:wipe-all": "prisma db execute --file ../../scripts/sql/wipe-all-companies-and-users.sql",
    "user:reset-password": "ts-node scripts/reset-user-password.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^5.13.0",
    "@supabase/storage-js": "^2.105.4",
    "@supabase/supabase-js": "^2.105.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.8.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "exceljs": "^4.4.0",
    "ioredis": "^5.4.1",
    "pdfmake": "^0.3.9",
    "puppeteer": "^24.42.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/pdfmake": "^0.3.3",
    "prisma": "^5.13.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}
