# --- Supabase PostgreSQL (Railway / production) ---
# Ilova (NestJS / Railway): Transaction pooler — port 6543 (5432 EMAS)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=15"
# Migratsiya: Session pooler — port 5432
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Migratsiya (faqat `prisma migrate deploy` vaqtida): Session pooler — port 5432
# Deploy/start da ishlatilmaydi; Railway start commandda migrate qo‘ymang.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- Lokal (ixtiyoriy) ---
# IPv6 bo‘lsa: db.PROJECT_REF.supabase.co:5432
# Windows IPv4: yuqoridagi pooler URL lardan foydalaning

PORT=4002
JWT_SECRET="change-me"

# Telegram bot — veb havola (menyu «Veb-ilovani ochish»)
# FRONTEND_URL=https://your-app.vercel.app

# Kunlik hisobotlar va POS «bugun» (default: Asia/Tashkent)
# APP_TIMEZONE=Asia/Tashkent

# Yangi kompaniya sinov muddati (kun) — marketing bilan bir xil (default: 7)
# TRIAL_DAYS=7

# Platforma admin (obuna boshqaruvi) — Railway API servisida
# PLATFORM_ADMIN_EMAILS=admin@example.com
# PLATFORM_ADMIN_LOGINS=your-login
# Admin panel PIN (kamida 4 belgi) — /dashboard/platform-admin ochilganda
# PLATFORM_ADMIN_PIN=your-secret-pin
#
# Alias (oldingi Railway nomlari ham ishlaydi):
# ADMIN_EMAIL=admin@example.com
# ADMIN_LOGIN=your-login
# ADMIN_PASSWORD=your-secret-pin

# --- Redis: Railway API servisida Redis plugin → REDIS_URL reference qo'ying ---
# REDIS_URL="redis://localhost:6379"
# REDIS_PRIVATE_URL / REDIS_PUBLIC_URL ham qabul qilinadi (Railway)
# DASHBOARD_CACHE_TTL_MS=90000
# AUTH_ME_CACHE_TTL_MS=60000
# FEATURES_CACHE_TTL_MS=300000
# INVENTORY_COUNTS_CACHE_TTL_MS=30000
# CATEGORY_CACHE_TTL_MS=300000
# ORDERS_HUB_CACHE_TTL_MS=45000
# POS_CATALOG_CACHE_TTL_MS=30000

# --- Hisobotlar / og‘ir so‘rovlar himoyasi ---
# REPORT_DEFAULT_RANGE_DAYS=90
# REPORT_MAX_RANGE_DAYS=366
# REPORT_MAX_MOVEMENT_ROWS=25000
# IMPORT_PREVIEW_MAX_ROWS=2500
# IMPORT_CONFIRM_MAX_ROWS=5000
# IMPORT_BATCH_SIZE=40
# IMPORT_ROW_TX_BATCH_SIZE=25
# IMPORT_SYNC_MAX_ROWS=250
# RECEIPT_MAX_ACCEPT_LINES=800

# --- Support chat (Sozlamalar → Yordam) ---
# SUPPORT_TELEGRAM_USERNAME=tadbirkor_support
# SUPPORT_TELEGRAM_CHAT_ID=123456789
# SUPPORT_EMAIL=support@tadbirkor.uz
# SUPPORT_PHONE=+998901234567
# SUPPORT_HOURS=Dush–Juma, 09:00–18:00
