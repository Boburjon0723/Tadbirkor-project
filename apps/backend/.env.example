# Go backend (port 4003) — mustaqil standalone
PORT=4003

# PostgreSQL — NestJS bilan BIR XIL bazaga ulanish kerak.
# Supabase: Go uchun 6543 (transaction pooler) EMAS — 5432 session yoki direct URL ishlating.
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/axis_erp

REDIS_URL=redis://localhost:6379
JWT_SECRET=change_me_same_as_apps_api
AUTH_COOKIE_NAME=access_token
AUTH_ME_CACHE_TTL_MS=60000
DASHBOARD_CACHE_TTL_MS=90000
CORS_ORIGINS=http://localhost:3000
NODE_ENV=development
# true (default) | false — productionda yopish uchun false
AUTH_REGISTRATION_ENABLED=true
TRIAL_DAYS=7

# Auth: parol tiklash telegram havolasi (@botsiz, masalan: MyAxisBot)
TELEGRAM_BOT_USERNAME=
# Lokalda Railway bot bilan ziddiyat bo'lmasin — tokenni komentga oling
# TELEGRAM_BOT_TOKEN=
# Production webhook: TELEGRAM_WEBHOOK_URL=https://<go-api>/api/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=

# Support moduli (ixtiyoriy)
SUPPORT_TELEGRAM_USERNAME=
SUPPORT_PHONE=
SUPPORT_EMAIL=
SUPPORT_HOURS=

# Platform admin (auth/me da canWrite)
PLATFORM_ADMIN_LOGINS=
PLATFORM_ADMIN_EMAILS=

# Product import (Nest bilan bir xil defaultlar)
# IMPORT_SYNC_MAX_ROWS=250
# IMPORT_CONFIRM_MAX_ROWS=5000
# IMPORT_BATCH_SIZE=50
